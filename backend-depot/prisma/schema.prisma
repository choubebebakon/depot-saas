  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model HistoriqueFidelite {
  id         String            @id @default(uuid())
  fideliteId String
  points     Int
  motif      String
  createdAt  DateTime          @default(now())
  fidelite   ProgrammeFidelite @relation(fields: [fideliteId], references: [id], onDelete: Cascade)

  @@index([fideliteId])
}

model Recette {
  id            String              @id @default(uuid())
  tenantId      String
  articleId     String              @unique
  nom           String
  instructions  String?
  tempsPrep     Int?
  tempsCuisson  Int?
  temperature   Int?
  portionsUnite Int                 @default(1)
  createdAt     DateTime            @default(now())
  ingredients   IngredientRecette[]
  productions   ProductionJour[]
  article       Article             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model IngredientRecette {
  id        String  @id @default(uuid())
  recetteId String
  articleId String
  quantite  Float
  unite     String
  article   Article @relation(fields: [articleId], references: [id])
  recette   Recette @relation(fields: [recetteId], references: [id], onDelete: Cascade)

  @@index([recetteId])
}

model ProductionJour {
  id               String   @id @default(uuid())
  tenantId         String
  recetteId        String
  date             DateTime @default(now())
  quantiteProduite Int
  quantiteVendue   Int      @default(0)
  quantiteInvendue Int      @default(0)
  coutProduction   Float?
  notes            String?
  recette          Recette  @relation(fields: [recetteId], references: [id], onDelete: Cascade)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([date])
}

model CompositionGlace {
  id          String   @id @default(uuid())
  tenantId    String
  commandeId  String   @unique
  contenant   String
  parfums     String
  supplements String?
  prix        Float
  commande    Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model LivreDetail {
  id            String  @id @default(uuid())
  tenantId      String
  articleId     String  @unique
  isbn          String? @unique
  auteur        String?
  editeur       String?
  anneeParution Int?
  genre         String?
  langue        String? @default("FR")
  nbPages       Int?
  article       Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model CommandeSpeciale {
  id           String                 @id @default(uuid())
  tenantId     String
  clientId     String
  designation  String
  isbn         String?
  quantite     Int                    @default(1)
  statut       CommandeSpecialeStatut @default(EN_ATTENTE)
  dateCommande DateTime               @default(now())
  dateArrivee  DateTime?
  notes        String?
  client       Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([statut])
}

model DossierMedical {
  id                String         @id @default(uuid())
  tenantId          String
  clientId          String         @unique
  groupeSanguin     String?
  allergies         String?
  antecedents       String?
  traitementEnCours String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  consultations     Consultation[]
  client            Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Consultation {
  id            String         @id @default(uuid())
  tenantId      String
  dossierId     String
  medecinId     String?
  specialite    String?
  motif         String
  examen        String?
  diagnostic    String?
  montant       Float          @default(0)
  statut        ConsultStatut  @default(EN_COURS)
  date          DateTime       @default(now())
  notes         String?
  dossier       DossierMedical @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([tenantId])
  @@index([dossierId])
}

model Prescription {
  id             String       @id @default(uuid())
  consultationId String
  articleId      String?
  medicament     String
  dosage         String?
  posologie      String?
  duree          String?
  article        Article?     @relation(fields: [articleId], references: [id])
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([consultationId])
}

model RendezVousMedical {
  id         String           @id @default(uuid())
  tenantId   String
  clientId   String
  medecinId  String?
  specialite String?
  dateHeure  DateTime
  motif      String?
  statut     RdvMedicalStatut @default(PLANIFIE)
  notes      String?
  createdAt  DateTime         @default(now())
  client     Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dateHeure])
}

model VehiculeTransport {
  id              String   @id @default(uuid())
  tenantId        String
  immatriculation String
  type            String
  marque          String?
  modele          String?
  capaciteKg      Float?
  capaciteM3      Float?
  chauffeurId     String?
  disponible      Boolean  @default(true)
  createdAt       DateTime @default(now())
  trajets         Trajet[]
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Colis {
  id            String      @id @default(uuid())
  tenantId      String
  expediteurId  String?
  destinataire  String
  telephoneDest String?
  adresseDest   String
  villeDest     String
  poids         Float?
  dimensions    String?
  description   String?
  valeur        Float?
  reference     String      @unique
  statut        ColisStatut @default(ENREGISTRE)
  montant       Float       @default(0)
  createdAt     DateTime    @default(now())
  trajetId      String?
  expediteur    Client?     @relation(fields: [expediteurId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trajet        Trajet?     @relation(fields: [trajetId], references: [id])

  @@index([tenantId])
  @@index([statut])
  @@index([reference])
}

model Trajet {
  id           String             @id @default(uuid())
  tenantId     String
  vehiculeId   String?
  chauffeurId  String?
  villeDepart  String
  villeArrivee String
  dateDepart   DateTime
  dateArrivee  DateTime?
  distance     Float?
  montant      Float              @default(0)
  statut       TrajetStatut       @default(PLANIFIE)
  notes        String?
  createdAt    DateTime           @default(now())
  colis        Colis[]
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicule     VehiculeTransport? @relation(fields: [vehiculeId], references: [id])

  @@index([tenantId])
  @@index([statut])
}

model BienImmobilier {
  id            String             @id @default(uuid())
  tenantId      String
  reference     String             @unique
  type          BienType
  adresse       String
  ville         String
  surface       Float?
  nbPieces      Int?
  etage         Int?
  loyer         Float
  charges       Float?
  depot         Float?
  disponible    Boolean            @default(true)
  description   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrats      ContratLocation[]
  interventions InterventionBien[]

  @@index([tenantId])
  @@index([disponible])
}

model ContratLocation {
  id          String          @id @default(uuid())
  tenantId    String
  bienId      String
  locataireId String
  dateDebut   DateTime
  dateFin     DateTime?
  loyer       Float
  charges     Float?
  depot       Float?
  statut      ContratStatut   @default(ACTIF)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bien        BienImmobilier  @relation(fields: [bienId], references: [id], onDelete: Cascade)
  locataire   Client          @relation(fields: [locataireId], references: [id], onDelete: Cascade)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paiements   PaiementLoyer[]

  @@index([tenantId])
  @@index([statut])
  @@index([bienId])
}

model PaiementLoyer {
  id           String              @id @default(uuid())
  tenantId     String
  contratId    String
  mois         String
  montant      Float
  charges      Float?              @default(0)
  modePaiement ModePaiement        @default(CASH)
  statut       PaiementLoyerStatut @default(PAYE)
  datePaiement DateTime            @default(now())
  dateEcheance DateTime
  notes        String?
  contrat      ContratLocation     @relation(fields: [contratId], references: [id], onDelete: Cascade)
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([contratId, mois])
  @@index([tenantId])
  @@index([statut])
}

model InterventionBien {
  id          String         @id @default(uuid())
  tenantId    String
  bienId      String
  type        String
  description String
  cout        Float?
  date        DateTime       @default(now())
  statut      String         @default("EFFECTUEE")
  bien        BienImmobilier @relation(fields: [bienId], references: [id], onDelete: Cascade)
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bienId])
}

model TypeChambre {
  id          String    @id @default(uuid())
  tenantId    String
  nom         String
  description String?
  capacite    Int       @default(1)
  prixNuit    Float
  equipements String?
  imageUrl    String?
  actif       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  chambres    Chambre[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Chambre {
  id            String             @id @default(uuid())
  tenantId      String
  numero        String
  etage         Int?
  typeChambreId String
  statut        ChambreStatut      @default(LIBRE)
  notes         String?
  createdAt     DateTime           @default(now())
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  typeChambre   TypeChambre        @relation(fields: [typeChambreId], references: [id])
  reservations  ReservationHotel[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([statut])
}

model ReservationHotel {
  id            String                 @id @default(uuid())
  tenantId      String
  clientId      String?
  chambreId     String
  reference     String                 @unique
  nomClient     String
  telephone     String?
  email         String?
  dateArrivee   DateTime
  dateDepart    DateTime
  nbNuits       Int
  nbPersonnes   Int                    @default(1)
  prixTotal     Float
  avance        Float                  @default(0)
  modePaiement  ModePaiement           @default(CASH)
  statut        ReservationHotelStatut @default(CONFIRMEE)
  source        String?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  consommations ConsommationHotel[]
  chambre       Chambre                @relation(fields: [chambreId], references: [id])
  client        Client?                @relation(fields: [clientId], references: [id])
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([statut])
  @@index([dateArrivee])
  @@index([chambreId])
}

model ConsommationHotel {
  id            String           @id @default(uuid())
  reservationId String
  articleId     String?
  designation   String
  quantite      Int              @default(1)
  prix          Float
  total         Float
  date          DateTime         @default(now())
  article       Article?         @relation(fields: [articleId], references: [id])
  reservation   ReservationHotel @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

