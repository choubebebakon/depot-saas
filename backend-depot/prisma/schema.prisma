generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum StatutAbonnement {
  TRIAL
  ACTIVE
  GRACE      
  READ_ONLY  
  EXPIRED
}

enum PlanAbonnement {
  MENSUEL
  ANNUEL
}

enum RoleUser {
  PATRON
  GERANT
  CAISSIER
  MAGASINIER
  COMMERCIAL
  COMPTABLE
}

enum StatutVente {
  PAYE
  ATTENTE
  ANNULE
}

enum TypeMouvement {
  ENTREE
  SORTIE
  SORTIE_VENTE
  SORTIE_GRATUITE
  TRANSFERT_SORTIE
  TRANSFERT_ENTREE
  AJUSTEMENT_INVENTAIRE
  CASSE_AVARIE
  RETOUR_CLIENT
}

enum StatutTransfert {
  BROUILLON
  EN_COURS
  TERMINE
  ANNULE
}

enum StatutCommande {
  BROUILLON
  ENVOYE
  RECU
  ANNULE
}

enum TypeMouvementCaisse {
  ENCAISSEMENT_VENTE
  ENCAISSEMENT_DETTE
  DECAISSEMENT_DEPENSE
  DECAISSEMENT_VIDES
  FOND_INITIAL
  AJUSTEMENT
}

enum TypeMaintenance {
  VIDANGE
  PNEU
  FREINS
  CARBURANT
  REPARATION
  REVISION
  AUTRE
}

enum StatutMaintenance {
  PLANIFIE
  EFFECTUE
  ANNULE
}

enum ModePaiement {
  CASH
  ORANGE_MONEY
  MTN_MOMO
  CREDIT
  MIXTE
}

enum StatutTournee {
  OUVERTE
  CLOTURE_COMMERCIALE
  VALIDEE
  ANNULEE
}

enum StatutReception {
  EN_COURS
  VALIDEE
  ANNULEE
}

enum TypeConsigne {
  BOUTEILLE_33CL
  BOUTEILLE_60CL
  CASIER
  PALETTE
  PACK_EAU
}

enum StatutDette {
  EN_COURS
  PARTIELLEMENT_PAYEE
  SOLDEE
  EN_LITIGE
}

// ============================================================
// MODELES
// ============================================================

model Tenant {
  id            String   @id @default(uuid())
  nomEntreprise String
  emailPatron   String?
  telephone     String?
  dateEssaiFin  DateTime?
  estActif      Boolean  @default(true)
  graceUntil    DateTime? 

  statutAbonnement StatutAbonnement @default(TRIAL)
  dateExpiration   DateTime?
  plan             PlanAbonnement?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slogan      String?
  adresse     String?
  logo        String?   
  messageFin  String?   @default("Merci de votre fidélité !")

  depots     Depot[]
  articles   Article[]
  mouvements MouvementStock[]
  users      User[]
  ventes     Vente[]
  paiements  PaiementSouscription[]

  clients       Client[]
  familles Famille[]
  lots LotStock[]
  maintenances        MaintenanceTricycle[]
  carburants          ConsommationCarburant[]
  commissions         Commission[]
  conditionnements Conditionnement[]
  parametresCommission ParametreCommission[]
  marques  Marque[]
  fournisseurs  Fournisseur[]
  receptions    ReceptionFournisseur[]
  commandes     CommandeFournisseur[]
  tournees      Tournee[]
  tricycles     Tricycle[]
  sessionsCaisse SessionCaisse[]
  depenses      Depense[]
  typesConsigne TypeConsigneConfig[]
  transferts    TransfertStock[]
}

model PaiementSouscription {
  id           String   @id @default(uuid())
  montant      Float
  devise       String   @default("FCFA")
  reference    String?
  statut       String
  datePaiement DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      RoleUser
  nom       String?  
  tenantId  String
  depotId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot  Depot? @relation(fields: [depotId], references: [id])

  ventesCreees    Vente[]          @relation("VenteCreateur")
  commissions Commission[]
  tourneesOuvertes Tournee[]
  sessionsCaisse  SessionCaisse[]
  commandesCreees CommandeFournisseur[]

  @@index([tenantId])
  @@index([depotId])
}

model Depot {
  id          String @id @default(uuid())
  nom         String
  adresse     String
  emplacement String
  codePrefix  String @default("DEP") 
  tenantId    String

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stocks     Stock[]
  mouvements MouvementStock[]
  ventes     Vente[]

  receptions     ReceptionFournisseur[]
  commandes      CommandeFournisseur[]
  lots LotStock[]
  users          User[]
  clients        Client[]
  dettesClients  DetteClient[]
  portefeuillesConsigne PortefeuilleConsigne[]
  mouvementsConsigne MouvementConsigne[]
  fournisseurs   Fournisseur[]
  tricycles      Tricycle[]
  tournees       Tournee[]
  sessionsCaisse SessionCaisse[]
  journauxAudit  JournalAudit[]
  maintenances   MaintenanceTricycle[]
  carburants     ConsommationCarburant[]
  commissions    Commission[]
  depenses       Depense[]
  transfertsSource TransfertStock[] @relation("TransfertSource")
  transfertsDest   TransfertStock[] @relation("TransfertDest")

  @@index([tenantId])
}

model Famille {
  id       String @id @default(uuid())
  nom      String 
  emoji    String @default("📦") 
  tenantId String

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marques  Marque[]
  articles Article[]

  @@index([tenantId])
}

model Marque {
  id        String @id @default(uuid())
  nom       String 
  familleId String
  tenantId  String

  famille  Famille   @relation(fields: [familleId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  articles Article[]

  @@index([familleId])
  @@index([tenantId])
}

model Article {
  id          String   @id @default(uuid())
  designation String   
  format      String   @default("") 
  prixVente   Float
  prixAchat   Float    @default(0)
  seuilCritique Int    @default(0)
  estConsigne Boolean  @default(false)

  uniteParCasier  Int @default(12)  
  uniteParPack    Int @default(6)   
  uniteParPalette Int @default(120) 

  familleId String?
  marqueId  String?
  tenantId  String
  createdAt DateTime @default(now())

  famille      Famille?         @relation(fields: [familleId], references: [id])
  marque       Marque?          @relation(fields: [marqueId], references: [id])
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lots LotStock[]
  stocks       Stock[]
  mouvements   MouvementStock[]
  lignesVentes LigneVente[]
  lignesReception LigneReception[]
  lignesCommande  LigneCommandeFournisseur[]
  lignesChargement LigneChargement[]
  conditionnements Conditionnement[] 
  lignesTransfert LigneTransfert[]

  @@index([tenantId])
  @@index([familleId])
  @@index([marqueId])
}

model Conditionnement {
  id               String  @id @default(uuid())
  nom              String  
  type             String  
  quantiteUnitaire Int     
  prixVente        Float

  articleId        String
  article          Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  tenantId         String
  tenant           Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  lignesVente      LigneVente[]

  @@index([articleId])
  @@index([tenantId])
}

model Stock {
  id       String @id @default(uuid())
  quantite Int    @default(0)
  seuilCritique Int? // Seuil spécifique au dépôt

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  depotId String
  depot   Depot   @relation(fields: [depotId], references: [id], onDelete: Cascade)

  tricycleId String?
  tricycle   Tricycle? @relation(fields: [tricycleId], references: [id])

  @@unique([articleId, depotId])
  @@index([depotId])
  @@index([articleId])
}

model LotStock {
  id          String   @id @default(uuid())
  quantite    Int      @default(0)
  quantiteInitiale Int @default(0)
  dlc         DateTime? 
  numeroLot   String?   
  createdAt   DateTime @default(now())

  articleId   String
  depotId      String
  tenantId    String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  depot    Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([depotId])
  @@index([tenantId])
  @@index([dlc])
}

model MouvementStock {
  id        String        @id @default(uuid())
  type      TypeMouvement
  quantite  Float
  motif     String?
  photoUrl  String?       
  createdAt DateTime      @default(now())

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  depotId String
  depot   Depot   @relation(fields: [depotId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  tourneeId String?
  tournee   Tournee? @relation(fields: [tourneeId], references: [id])

  @@index([tenantId])
  @@index([depotId])
  @@index([articleId])
}

model TransfertStock {
  id        String          @id @default(uuid())
  reference String          @unique
  statut    StatutTransfert @default(BROUILLON)
  motif     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  sourceDepotId String
  sourceDepot   Depot  @relation("TransfertSource", fields: [sourceDepotId], references: [id])

  destDepotId   String
  destDepot     Depot  @relation("TransfertDest", fields: [destDepotId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  lignes LigneTransfert[]

  @@index([tenantId])
}

model LigneTransfert {
  id       String @id @default(uuid())
  quantite Int

  transfertId String
  transfert   TransfertStock @relation(fields: [transfertId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id])

  @@index([transfertId])
}

model CommandeFournisseur {
  id           String         @id @default(uuid())
  reference    String         @unique
  statut       StatutCommande @default(BROUILLON)
  total        Float          @default(0)
  dateCommande DateTime       @default(now())
  dateReceptionPrev DateTime?
  note         String?

  fournisseurId String
  fournisseur   Fournisseur @relation(fields: [fournisseurId], references: [id])

  depotId String
  depot   Depot  @relation(fields: [depotId], references: [id])

  createurId String
  createur   User   @relation(fields: [createurId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  lignes LigneCommandeFournisseur[]

  @@index([tenantId])
  @@index([depotId])
}

model LigneCommandeFournisseur {
  id             String @id @default(uuid())
  quantite       Int
  prixAchatUnit  Float

  commandeId String
  commande   CommandeFournisseur @relation(fields: [commandeId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id])

  @@index([commandeId])
}

model Vente {
  id        String      @id @default(uuid())
  reference String      @unique
  total     Float
  statut    StatutVente @default(ATTENTE)
  date      DateTime    @default(now())
  motifAnnulation String? 

  modePaiement ModePaiement @default(CASH) 
  montantCash  Float        @default(0)     
  montantOM    Float        @default(0)     
  montantMoMo  Float        @default(0)    
  montantCredit Float       @default(0)    

  tenantId  String
  depotId    String
  clientId  String?   
  createurId String?  
  tourneeId  String?  

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot     Depot         @relation(fields: [depotId], references: [id], onDelete: Cascade)
  client   Client?      @relation(fields: [clientId], references: [id])
  createur User?        @relation("VenteCreateur", fields: [createurId], references: [id])
  tournee  Tournee?     @relation(fields: [tourneeId], references: [id])
  lignes   LigneVente[]

  mouvementsConsigne MouvementConsigne[]

  @@index([tenantId])
  @@index([depotId])
  @@index([clientId])
}

model LigneVente {
  id           String @id @default(uuid())
  quantite     Int
  prixUnitaire Float
  remise       Float  @default(0) 
  total        Float

  venteId   String
  articleId String

  vente   Vente   @relation(fields: [venteId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  conditionnementId String?
  conditionnement   Conditionnement? @relation(fields: [conditionnementId], references: [id])
  
  casierMixte Boolean @default(false)
  composition Json?   

  @@index([venteId])
  @@index([articleId])
}

model Client {
  id         String  @id @default(uuid())
  nom        String
  telephone  String?
  adresse    String?
  plafondCredit Float @default(0)  
  soldeCredit   Float @default(0)  
  tenantId   String
  depotId    String?
  createdAt  DateTime @default(now())

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot    Depot?  @relation(fields: [depotId], references: [id])
  ventes   Vente[]
  dettes   DetteClient[]

  portefeuilleConsignes PortefeuilleConsigne[]

  @@index([tenantId])
  @@index([depotId])
}

model DetteClient {
  id          String     @id @default(uuid())
  montant     Float
  montantPaye Float      @default(0)
  statut      StatutDette @default(EN_COURS)
  reference   String?    
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  clientId  String
  tenantId  String
  depotId   String?
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  depot     Depot? @relation(fields: [depotId], references: [id])

  @@index([clientId])
  @@index([tenantId])
  @@index([depotId])
}

model TypeConsigneConfig {
  id          String       @id @default(uuid())
  type        TypeConsigne
  valeurXAF   Float        
  description String?
  tenantId    String

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mouvementsConsigne    MouvementConsigne[]
  portefeuillesConsigne PortefeuilleConsigne[]

  @@unique([tenantId, type])
  @@index([tenantId])
}

model PortefeuilleConsigne {
  id       String @id @default(uuid())
  quantite Int    @default(0) 

  clientId        String
  typeConsigneId  String
  depotId         String?

  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  typeConsigne  TypeConsigneConfig @relation(fields: [typeConsigneId], references: [id])
  depot         Depot?             @relation(fields: [depotId], references: [id])

  @@unique([clientId, typeConsigneId])
  @@index([depotId])
}

model MouvementConsigne {
  id        String   @id @default(uuid())
  quantite  Int
  estSortie Boolean  
  estRemboursementCash Boolean @default(false) 
  montantRembourse Float @default(0)
  motif     String?
  createdAt DateTime @default(now())

  typeConsigneId String
  typeConsigne   TypeConsigneConfig @relation(fields: [typeConsigneId], references: [id])

  venteId   String?
  vente     Vente?  @relation(fields: [venteId], references: [id])

  tenantId  String
  depotId   String?
  depot     Depot?  @relation(fields: [depotId], references: [id])

  @@index([tenantId])
  @@index([venteId])
  @@index([depotId])
}

model Fournisseur {
  id        String   @id @default(uuid())
  nom       String
  telephone String?
  solde     Float    @default(0) 
  tenantId  String
  depotId   String?
  createdAt DateTime @default(now())

  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot      Depot?                 @relation(fields: [depotId], references: [id])
  receptions ReceptionFournisseur[]
  commandes  CommandeFournisseur[]

  @@index([tenantId])
  @@index([depotId])
}

model ReceptionFournisseur {
  id        String          @id @default(uuid())
  reference String          @unique
  statut    StatutReception @default(EN_COURS)
  modePaiement ModePaiement @default(CASH)
  montantPaye Float         @default(0)
  montantDette Float        @default(0)
  numBordereau String?      
  motifAnnulation String?
  createdAt DateTime        @default(now())

  fournisseurId String
  depotId        String
  tenantId      String

  fournisseur Fournisseur @relation(fields: [fournisseurId], references: [id])
  depot        Depot        @relation(fields: [depotId], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lignes      LigneReception[]

  @@index([tenantId])
  @@index([depotId])
}

model LigneReception {
  id              String @id @default(uuid())
  quantiteCommandee Int  @default(0)
  quantiteLivree   Int
  quantiteGratuite Int   @default(0) 
  uniteUsed        String? 
  prixAchatUnitaire Float

  receptionId String
  articleId   String

  reception ReceptionFournisseur @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  article   Article              @relation(fields: [articleId], references: [id])

  @@index([receptionId])
}

model Tricycle {
  id       String  @id @default(uuid())
  nom      String  
  estLibre Boolean @default(true) 
  tenantId String
  depotId  String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot    Depot?    @relation(fields: [depotId], references: [id])
  maintenances   MaintenanceTricycle[]
  carburants     ConsommationCarburant[]
  tournees Tournee[]
  stocks   Stock[]

  @@index([tenantId])
  @@index([depotId])
}

model Tournee {
  id        String        @id @default(uuid())
  reference String        @unique
  statut    StatutTournee @default(OUVERTE)
  dateOuverture DateTime  @default(now())
  dateCloture   DateTime?

  cashRemis     Float  @default(0)
  omRemis       Float  @default(0)
  momoRemis     Float  @default(0)
  noteCloture   String?

  ecartStock    Float? 
  noteValidation String?

  depotId       String
  tricycleId   String
  commercialId String
  tenantId     String

  depot       Depot     @relation(fields: [depotId], references: [id])
  tricycle   Tricycle @relation(fields: [tricycleId], references: [id])
  commercial User     @relation(fields: [commercialId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  lignesChargement LigneChargement[]
  ventes           Vente[]
  mouvements       MouvementStock[]

  @@index([tenantId])
  @@index([depotId])
}

model LigneChargement {
  id               String @id @default(uuid())
  quantiteChargee  Int
  quantiteRetour   Int    @default(0) 
  quantiteVendue   Int    @default(0)

  tourneeId String
  articleId String

  tournee Tournee @relation(fields: [tourneeId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id])

  @@index([tourneeId])
}

model SessionCaisse {
  id           String    @id @default(uuid())
  fondInitial  Float     @default(0)
  fondFinal    Float?    
  ecart        Float?    
  motifEcart   String?
  estOuverte   Boolean   @default(true)
  dateOuverture DateTime @default(now())
  dateCloture   DateTime?

  depotId    String
  userId    String
  tenantId  String

  depot      Depot    @relation(fields: [depotId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mouvements MouvementCaisse[]

  @@index([tenantId])
  @@index([depotId])
}

model MouvementCaisse {
  id        String               @id @default(uuid())
  type      TypeMouvementCaisse
  montant   Float
  motif     String?
  reference String?              
  createdAt DateTime             @default(now())

  sessionId String
  session   SessionCaisse @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Depense {
  id        String   @id @default(uuid())
  categorie String   
  montant   Float
  motif     String
  photoUrl  String?
  createdAt DateTime @default(now())

  depotId   String
  tenantId String

  depot   Depot   @relation(fields: [depotId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([depotId])
}

model JournalAudit {
  id           String   @id @default(uuid())
  tenantId     String
  depotId      String?
  actorUserId  String?
  actorEmail   String?
  actorRole    String?
  action       String
  targetType   String
  targetId     String?
  reference    String?
  description  String
  metadataText String?
  createdAt    DateTime @default(now())
  depot        Depot?   @relation(fields: [depotId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([depotId])
}

model MaintenanceTricycle {
  id          String            @id @default(uuid())
  type        TypeMaintenance
  statut      StatutMaintenance @default(PLANIFIE)
  description String
  cout        Float             @default(0)
  kilometrage Float?            
  photoUrl    String?
  dateEffectue DateTime?
  datePlanifie DateTime?
  createdAt   DateTime          @default(now())

  tricycleId String
  tenantId   String
  depotId    String?

  tricycle Tricycle @relation(fields: [tricycleId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot    Depot?   @relation(fields: [depotId], references: [id])

  @@index([tricycleId])
  @@index([tenantId])
  @@index([depotId])
}

model ConsommationCarburant {
  id          String   @id @default(uuid())
  litres      Float
  prixLitre   Float
  montantTotal Float
  kilometrage Float?
  nbTours     Int      @default(0) 
  createdAt   DateTime @default(now())

  tricycleId String
  tenantId   String
  depotId    String?

  tricycle Tricycle @relation(fields: [tricycleId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot    Depot?   @relation(fields: [depotId], references: [id])

  @@index([tricycleId])
  @@index([tenantId])
  @@index([depotId])
}

model Commission {
  id          String   @id @default(uuid())
  montant     Float
  tauxApplique Float   
  periode     String   
  estPayee    Boolean  @default(false)
  datePaiement DateTime?
  createdAt   DateTime @default(now())

  userId   String
  tenantId String
  depotId  String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  depot  Depot? @relation(fields: [depotId], references: [id])

  @@unique([userId, periode])
  @@index([tenantId])
  @@index([userId])
  @@index([depotId])
}

model ParametreCommission {
  id          String @id @default(uuid())
  taux        Float  
  description String @default("")
  estActif    Boolean @default(true)
  tenantId    String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
