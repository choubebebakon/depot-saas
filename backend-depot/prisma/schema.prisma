generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model PaiementSouscription {
  id           String   @id @default(uuid())
  montant      Float
  devise       String   @default("FCFA")
  reference    String?
  statut       String
  datePaiement DateTime @default(now())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Famille {
  id       String    @id @default(uuid())
  nom      String
  emoji    String    @default("📦")
  tenantId String
  articles Article[]
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  marques  Marque[]

  @@index([tenantId])
}

model Marque {
  id        String    @id @default(uuid())
  nom       String
  familleId String
  tenantId  String
  articles  Article[]
  famille   Famille   @relation(fields: [familleId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([familleId])
  @@index([tenantId])
}

model Categorie {
  id          String    @id @default(uuid())
  tenantId    String
  nom         String
  description String?
  couleur     String?   @default("#6366f1")
  icone       String?   @default("🏷️")
  actif       Boolean   @default(true)
  ordre       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, actif])
}

model Article {
  id                 String                     @id @default(uuid())
  designation        String
  format             String                     @default("")
  prixVente          Float
  prixAchat          Float                      @default(0)
  seuilCritique      Int                        @default(0)
  estConsigne        Boolean                    @default(false)
  uniteParCasier     Int                        @default(12)
  uniteParPack       Int                        @default(6)
  uniteParPalette    Int                        @default(120)
  familleId          String?
  marqueId           String?
  tenantId           String
  createdAt          DateTime                   @default(now())
  codeBarres         String?
  prixGros           Float?
  unite              String                     @default("PIECE")
  categorieId        String?
  alimentations      AlimentationElevage[]
  categorie          Categorie?                 @relation(fields: [categorieId], references: [id])
  famille            Famille?                   @relation(fields: [familleId], references: [id])
  marque             Marque?                    @relation(fields: [marqueId], references: [id])
  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codesBarres        CodeBarresArticle[]
  conditionnements   Conditionnement[]
  consommationsHotel ConsommationHotel[]
  recettes           IngredientRecette[]
  lignesChargement   LigneChargement[]
  lignesCommande     LigneCommandeFournisseur[]
  lignesDevis        LigneDevis[]
  lignesLivraisonBTP LigneLivraisonBTP[]
  lignesReception    LigneReception[]
  lignesTransfert    LigneTransfert[]
  lignesVentes       LigneVente[]
  livreDetail        LivreDetail?
  lots               LotStock[]
  medicament         Medicament?
  mouvements         MouvementStock[]
  piecesGarage       PieceGarage[]
  piecesReparation   PieceReparation[]
  prescriptions      Prescription[]
  produitCosmetique  ProduitCosmetique?
  promotions         Promotion[]
  rayons             RayonArticle[]
  recettesProduit    Recette?
  stocks             Stock[]
  telephone          Telephone?

  @@index([tenantId])
  @@index([familleId])
  @@index([marqueId])
  @@index([categorieId])
}

model Conditionnement {
  id               String       @id @default(uuid())
  nom              String
  type             String
  quantiteUnitaire Int
  prixVente        Float
  articleId        String
  tenantId         String
  article          Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lignesVente      LigneVente[]

  @@index([articleId])
  @@index([tenantId])
}

model Stock {
  id            String    @id @default(uuid())
  quantite      Int       @default(0)
  seuilCritique Int?
  articleId     String
  depotId       String
  tricycleId    String?
  article       Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  depot         Depot     @relation(fields: [depotId], references: [id], onDelete: Cascade)
  tricycle      Tricycle? @relation(fields: [tricycleId], references: [id])

  @@unique([articleId, depotId])
  @@index([depotId])
  @@index([articleId])
}

model LotStock {
  id               String    @id @default(uuid())
  quantite         Int       @default(0)
  quantiteInitiale Int       @default(0)
  dlc              DateTime?
  numeroLot        String?
  createdAt        DateTime  @default(now())
  articleId        String
  depotId          String
  tenantId         String
  article          Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  depot            Depot     @relation(fields: [depotId], references: [id], onDelete: Cascade)
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([depotId])
  @@index([tenantId])
  @@index([dlc])
}

model MouvementStock {
  id        String        @id @default(uuid())
  type      TypeMouvement
  quantite  Float
  motif     String?
  photoUrl  String?
  createdAt DateTime      @default(now())
  articleId String
  depotId   String
  tenantId  String
  tourneeId String?
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  depot     Depot         @relation(fields: [depotId], references: [id], onDelete: Cascade)
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournee   Tournee?      @relation(fields: [tourneeId], references: [id])

  @@index([tenantId])
  @@index([depotId])
  @@index([articleId])
}

model TransfertStock {
  id            String           @id @default(uuid())
  reference     String           @unique
  statut        StatutTransfert  @default(BROUILLON)
  motif         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sourceDepotId String
  destDepotId   String
  tenantId      String
  lignes        LigneTransfert[]
  destDepot     Depot            @relation("TransfertDest", fields: [destDepotId], references: [id])
  sourceDepot   Depot            @relation("TransfertSource", fields: [sourceDepotId], references: [id])
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model LigneTransfert {
  id          String         @id @default(uuid())
  quantite    Int
  transfertId String
  articleId   String
  article     Article        @relation(fields: [articleId], references: [id])
  transfert   TransfertStock @relation(fields: [transfertId], references: [id], onDelete: Cascade)

  @@index([transfertId])
}

model PieceReparation {
  id           String     @id @default(uuid())
  reparationId String
  nom          String
  quantite     Int        @default(1)
  prix         Float      @default(0)
  articleId    String
  article      Article    @relation(fields: [articleId], references: [id])
  reparation   Reparation @relation(fields: [reparationId], references: [id], onDelete: Cascade)
}

model Telephone {
  id           String       @id @default(uuid())
  tenantId     String
  articleId    String       @unique
  imei         String       @unique
  marque       String
  modele       String
  couleur      String?
  stockage     String?
  garantieMois Int          @default(12)
  dateAchat    DateTime?
  vendu        Boolean      @default(false)
  createdAt    DateTime     @default(now())
  dateVente    DateTime?
  imei2        String?
  ram          String?
  updatedAt    DateTime     @updatedAt
  reparations  Reparation[]
  article      Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Reparation {
  id           String            @id @default(uuid())
  tenantId     String
  clientId     String
  imei         String?
  marque       String?
  modele       String?
  probleme     String
  diagnostic   String?
  montant      Float?
  statut       ReparationStatut  @default(RECU)
  technicienId String?
  dateDepot    DateTime          @default(now())
  dateRetrait  DateTime?
  avance       Float             @default(0)
  createdAt    DateTime          @default(now())
  montantDevis Float?
  montantFinal Float             @default(0)
  notes        String?
  telephoneId  String?
  updatedAt    DateTime          @updatedAt
  pieces       PieceReparation[]
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  telephone    Telephone?        @relation(fields: [telephoneId], references: [id])
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CommandeFournisseur {
  id                String                     @id @default(uuid())
  reference         String                     @unique
  statut            StatutCommande             @default(BROUILLON)
  total             Float                      @default(0)
  dateCommande      DateTime                   @default(now())
  dateReceptionPrev DateTime?
  note              String?
  fournisseurId     String
  depotId           String
  createurId        String
  tenantId          String
  createur          User                       @relation(fields: [createurId], references: [id])
  depot             Depot                      @relation(fields: [depotId], references: [id])
  fournisseur       Fournisseur                @relation(fields: [fournisseurId], references: [id])
  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lignes            LigneCommandeFournisseur[]

  @@index([tenantId])
  @@index([depotId])
}

model LigneCommandeFournisseur {
  id            String              @id @default(uuid())
  quantite      Int
  prixAchatUnit Float
  commandeId    String
  articleId     String
  article       Article             @relation(fields: [articleId], references: [id])
  commande      CommandeFournisseur @relation(fields: [commandeId], references: [id], onDelete: Cascade)

  @@index([commandeId])
}

model Vente {
  id                 String              @id @default(uuid())
  reference          String              @unique
  total              Float
  statut             StatutVente         @default(ATTENTE)
  date               DateTime            @default(now())
  motifAnnulation    String?
  modePaiement       ModePaiement        @default(CASH)
  montantCash        Float               @default(0)
  montantOM          Float               @default(0)
  montantMoMo        Float               @default(0)
  montantCredit      Float               @default(0)
  tenantId           String
  depotId            String
  clientId           String?
  createurId         String?
  tourneeId          String?
  lignes             LigneVente[]
  mouvementsConsigne MouvementConsigne[]
  client             Client?             @relation(fields: [clientId], references: [id])
  createur           User?               @relation("VenteCreateur", fields: [createurId], references: [id])
  depot              Depot               @relation(fields: [depotId], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tournee            Tournee?            @relation(fields: [tourneeId], references: [id])

  @@index([tenantId])
  @@index([depotId])
  @@index([clientId])
}

model LigneVente {
  id                String           @id @default(uuid())
  quantite          Int
  prix              Float
  remise            Float            @default(0)
  total             Float
  venteId           String
  articleId         String
  conditionnementId String?
  casierMixte       Boolean          @default(false)
  composition       Json?
  article           Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  conditionnement   Conditionnement? @relation(fields: [conditionnementId], references: [id])
  vente             Vente            @relation(fields: [venteId], references: [id], onDelete: Cascade)

  @@index([venteId])
  @@index([articleId])
}

model Client {
  id                    String                 @id @default(uuid())
  nom                   String
  email                 String?
  telephone             String?
  adresse               String?
  plafondCredit         Float                  @default(0)
  soldeCredit           Float                  @default(0)
  tenantId              String
  depotId               String?
  createdAt             DateTime               @default(now())
  chantiers             Chantier[]
  depot                 Depot?                 @relation(fields: [depotId], references: [id])
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  colisExpedies         Colis[]
  commandesSpeciales    CommandeSpeciale[]
  contratsLocation      ContratLocation[]
  credit                CreditClient?
  dettes                DetteClient[]
  devis                 Devis[]
  dossiersMedicaux      DossierMedical?
  ordonnances           Ordonnance[]
  portefeuilleConsignes PortefeuilleConsigne[]
  fidelite              ProgrammeFidelite?
  rendezVousMedical     RendezVousMedical[]
  rdvSalon              RendezVousSalon[]
  reparations           Reparation[]
  reservationsHotel     ReservationHotel[]
  ticketsPressing       TicketPressing[]
  vehicules             VehiculeClient[]
  ventes                Vente[]

  @@index([tenantId])
  @@index([depotId])
}

model DetteClient {
  id          String      @id @default(uuid())
  montant     Float
  montantPaye Float       @default(0)
  statut      StatutDette @default(EN_COURS)
  reference   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  clientId    String
  tenantId    String
  depotId     String?
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  depot       Depot?      @relation(fields: [depotId], references: [id])

  @@index([clientId])
  @@index([tenantId])
  @@index([depotId])
}

model TypeConsigneConfig {
  id                    String                 @id @default(uuid())
  type                  TypeConsigne
  valeurXAF             Float
  description           String?
  tenantId              String
  mouvementsConsigne    MouvementConsigne[]
  portefeuillesConsigne PortefeuilleConsigne[]
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
}

model PortefeuilleConsigne {
  id             String             @id @default(uuid())
  quantite       Int                @default(0)
  clientId       String
  typeConsigneId String
  depotId        String?
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  depot          Depot?             @relation(fields: [depotId], references: [id])
  typeConsigne   TypeConsigneConfig @relation(fields: [typeConsigneId], references: [id])

  @@unique([clientId, typeConsigneId])
  @@index([depotId])
}

model MouvementConsigne {
  id                   String             @id @default(uuid())
  quantite             Int
  estSortie            Boolean
  estRemboursementCash Boolean            @default(false)
  montantRembourse     Float              @default(0)
  motif                String?
  createdAt            DateTime           @default(now())
  typeConsigneId       String
  venteId              String?
  tenantId             String
  depotId              String?
  depot                Depot?             @relation(fields: [depotId], references: [id])
  typeConsigne         TypeConsigneConfig @relation(fields: [typeConsigneId], references: [id])
  vente                Vente?             @relation(fields: [venteId], references: [id])

  @@index([tenantId])
  @@index([venteId])
  @@index([depotId])
}

model Fournisseur {
  id           String                 @id @default(uuid())
  nom          String
  telephone    String?
  solde        Float                  @default(0)
  tenantId     String
  depotId      String?
  createdAt    DateTime               @default(now())
  adresse      String?
  email        String?
  notes        String?
  soldeInitial Float                  @default(0)
  commandes    CommandeFournisseur[]
  depot        Depot?                 @relation(fields: [depotId], references: [id])
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicaments  Medicament[]
  receptions   ReceptionFournisseur[]

  @@index([tenantId])
  @@index([depotId])
}

model ReceptionFournisseur {
  id              String           @id @default(uuid())
  reference       String           @unique
  statut          StatutReception  @default(EN_COURS)
  modePaiement    ModePaiement     @default(CASH)
  montantPaye     Float            @default(0)
  montantDette    Float            @default(0)
  numBordereau    String?
  motifAnnulation String?
  createdAt       DateTime         @default(now())
  fournisseurId   String
  depotId         String
  tenantId        String
  lignes          LigneReception[]
  depot           Depot            @relation(fields: [depotId], references: [id])
  fournisseur     Fournisseur      @relation(fields: [fournisseurId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([depotId])
}

model LigneReception {
  id                String               @id @default(uuid())
  quantiteCommandee Int                  @default(0)
  quantiteLivree    Int
  quantiteGratuite  Int                  @default(0)
  uniteUsed         String?
  prixAchatUnitaire Float
  receptionId       String
  articleId         String
  article           Article              @relation(fields: [articleId], references: [id])
  reception         ReceptionFournisseur @relation(fields: [receptionId], references: [id], onDelete: Cascade)

  @@index([receptionId])
}

model Tricycle {
  id           String                  @id @default(uuid())
  nom          String
  estLibre     Boolean                 @default(true)
  tenantId     String
  depotId      String?
  carburants   ConsommationCarburant[]
  maintenances MaintenanceTricycle[]
  stocks       Stock[]
  tournees     Tournee[]
  depot        Depot?                  @relation(fields: [depotId], references: [id])
  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([depotId])
}

model Tournee {
  id               String            @id @default(uuid())
  reference        String            @unique
  statut           StatutTournee     @default(OUVERTE)
  dateOuverture    DateTime          @default(now())
  dateCloture      DateTime?
  cashRemis        Float             @default(0)
  omRemis          Float             @default(0)
  momoRemis        Float             @default(0)
  noteCloture      String?
  ecartStock       Float?
  noteValidation   String?
  depotId          String
  tricycleId       String
  commercialId     String
  tenantId         String
  lignesChargement LigneChargement[]
  mouvements       MouvementStock[]
  commercial       User              @relation(fields: [commercialId], references: [id])
  depot            Depot             @relation(fields: [depotId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tricycle         Tricycle          @relation(fields: [tricycleId], references: [id])
  ventes           Vente[]

  @@index([tenantId])
  @@index([depotId])
}

model LigneChargement {
  id              String  @id @default(uuid())
  quantiteChargee Int
  quantiteRetour  Int     @default(0)
  quantiteVendue  Int     @default(0)
  tourneeId       String
  articleId       String
  article         Article @relation(fields: [articleId], references: [id])
  tournee         Tournee @relation(fields: [tourneeId], references: [id], onDelete: Cascade)

  @@index([tourneeId])
}

model SessionCaisse {
  id            String            @id @default(uuid())
  fondInitial   Float             @default(0)
  fondFinal     Float?
  ecart         Float?
  motifEcart    String?
  estOuverte    Boolean           @default(true)
  dateOuverture DateTime          @default(now())
  dateCloture   DateTime?
  depotId       String
  userId        String
  tenantId      String
  mouvements    MouvementCaisse[]
  depot         Depot             @relation(fields: [depotId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([depotId])
}

model MouvementCaisse {
  id        String              @id @default(uuid())
  type      TypeMouvementCaisse
  montant   Float
  motif     String?
  reference String?
  createdAt DateTime            @default(now())
  sessionId String
  session   SessionCaisse       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Depense {
  id        String   @id @default(uuid())
  categorie String
  montant   Float
  motif     String
  photoUrl  String?
  createdAt DateTime @default(now())
  depotId   String
  tenantId  String
  depot     Depot    @relation(fields: [depotId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([depotId])
}

model JournalAudit {
  id           String   @id @default(uuid())
  tenantId     String
  depotId      String?
  actorUserId  String?
  actorEmail   String?
  actorRole    String?
  action       String
  targetType   String
  targetId     String?
  reference    String?
  description  String
  metadataText String?
  createdAt    DateTime @default(now())
  depot        Depot?   @relation(fields: [depotId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([depotId])
}

model MaintenanceTricycle {
  id           String            @id @default(uuid())
  type         TypeMaintenance
  statut       StatutMaintenance @default(PLANIFIE)
  description  String
  cout         Float             @default(0)
  kilometrage  Float?
  photoUrl     String?
  dateEffectue DateTime?
  datePlanifie DateTime?
  createdAt    DateTime          @default(now())
  tricycleId   String
  tenantId     String
  depotId      String?
  depot        Depot?            @relation(fields: [depotId], references: [id])
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tricycle     Tricycle          @relation(fields: [tricycleId], references: [id], onDelete: Cascade)

  @@index([tricycleId])
  @@index([tenantId])
  @@index([depotId])
}

model ConsommationCarburant {
  id           String   @id @default(uuid())
  litres       Float
  prixLitre    Float
  montantTotal Float
  kilometrage  Float?
  nbTours      Int      @default(0)
  createdAt    DateTime @default(now())
  tricycleId   String
  tenantId     String
  depotId      String?
  depot        Depot?   @relation(fields: [depotId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tricycle     Tricycle @relation(fields: [tricycleId], references: [id], onDelete: Cascade)

  @@index([tricycleId])
  @@index([tenantId])
  @@index([depotId])
}

model Commission {
  id           String    @id @default(uuid())
  montant      Float
  tauxApplique Float
  periode      String
  estPayee     Boolean   @default(false)
  datePaiement DateTime?
  createdAt    DateTime  @default(now())
  userId       String
  tenantId     String
  depotId      String?
  depot        Depot?    @relation(fields: [depotId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periode])
  @@index([tenantId])
  @@index([userId])
  @@index([depotId])
}

model ParametreCommission {
  id          String  @id @default(uuid())
  taux        Float
  description String  @default("")
  estActif    Boolean @default(true)
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Tenant {
  id                   String                   @id @default(uuid())
  name                 String?
  nomEntreprise        String?
  emailPatron          String?
  telephone            String?
  status               TenantStatus             @default(TRIAL)
  statutAbonnement     StatutAbonnement         @default(TRIAL)
  plan                 String?
