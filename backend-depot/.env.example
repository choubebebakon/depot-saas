# ─── Base de données ────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/db   # PostgreSQL URL

# ─── JWT ────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_in_prod                # Access Token (15min)
JWT_REFRESH_SECRET=change_me_in_prod               # Refresh Token (30j)

# ─── MTN MoMo via Campay ────────────────────────
CAMPAY_APP_USERNAME=your_campay_username           # Identifiant Campay
CAMPAY_APP_PASSWORD=your_campay_password           # Mot de passe Campay
CAMPAY_WEBHOOK_SECRET=your_webhook_secret          # Signature HMAC Campay

# ─── Stripe (Carte Visa/MasterCard) ─────────────
STRIPE_SECRET_KEY=sk_live_xxx                      # Clé secrète Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_xxx                 # Clé publique (frontend)
STRIPE_WEBHOOK_SECRET=whsec_xxx                    # Signature webhook Stripe

# NotchPay (Mobile Money + Carte)
NOTCHPAY_PUBLIC_KEY=public_xxx
NOTCHPAY_PRIVATE_KEY=private_xxx
NOTCHPAY_HASH_KEY=hash_xxx
NOTCHPAY_ENDPOINT=https://api.notchpay.co

# ─── Monitoring ─────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx               # DSN projet Sentry

# ─── App ────────────────────────────────────────
NODE_ENV=development                               # development | production
APP_PORT=3000                                      # Port du serveur NestJS
FRONTEND_URL=http://localhost:5174                 # URL frontend (CORS)
